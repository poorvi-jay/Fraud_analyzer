# Database. Defaults to local SQLite if unset. Point this at a Supabase
# Postgres connection string (see supabase/schema.sql) for a real deployment.
#DATABASE_URL=sqlite:///./fraud_analyzer.db

# Context agent LLM provider. "mock" (default) needs no API key and uses a
# deterministic heuristic so the pipeline runs end-to-end without credentials.
# Set to "anthropic" and provide ANTHROPIC_API_KEY for real LLM reasoning.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# Anomaly agent decision threshold (score >= this is "high" anomaly).
# Tuned from ml/reports/baseline_comparison.md; override if you retrain.
ANOMALY_HIGH_THRESHOLD=0.5

# Rate limit on the public POST /transactions/review endpoint.
REVIEW_RATE_LIMIT=20/minute

# CORS origin for the frontend during local dev.
FRONTEND_ORIGIN=http://localhost:5173

# --- Phase 2 (not used yet, reserved for override auth) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
