# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/
.vite/

# Env
.env
.env.local

# data/*.csv is never committed -- regenerable via ml/prepare_paysim.py, and
# can be anywhere from ~2MB (synthetic stand-in) to 500MB+ (derived from the
# real Kaggle PaySim dataset, which is itself excluded below), well over
# GitHub's 100MB per-file limit in the real-data case. ml/models/ and
# ml/reports/ (much smaller, row-count-independent) stay committed so the
# repo is still a clickable demo without a training step first.
data/*.csv
*.db
*.sqlite3

# OS / editor
.DS_Store
*.swp

# Claude Code local session config
.claude/
